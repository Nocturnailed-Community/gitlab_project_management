        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="access_gitlab_branch" model="ir.model.access">
        <field name="name">gitlab.branch access</field>
        <field name="model_id" search="[('model', '=', 'gitlab.branch')]" model="ir.model"/>
        <field name="group_id" ref="project.group_project_manager"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="access_gitlab_commit" model="ir.model.access">
        <field name="name">gitlab.commit access</field>
        <field name="model_id" search="[('model', '=', 'gitlab.commit')]" model="ir.model"/>
        <field name="group_id" ref="project.group_project_manager"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
</odoo>
