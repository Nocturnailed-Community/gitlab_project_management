<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="gitlab_instance_view_tree" model="ir.ui.view">
        <field name="name">gitlab.instance.view.tree</field>
        <field name="model">gitlab.instance</field>
        <field name="arch" type="xml">
            <list string="GitLab Instances">
                <field name="name"/>
                <field name="base_url"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-info="state == 'draft'" decoration-danger="state == 'error'"/>
            </list>
        </field>
    </record>

    <record id="gitlab_instance_view_form" model="ir.ui.view">
        <field name="name">gitlab.instance.view.form</field>
        <field name="model">gitlab.instance</field>
        <field name="arch" type="xml">
            <form string="GitLab Instance">
                <header>
                    <button name="action_test_connection" type="object" string="Test Connection" class="oe_highlight" invisible="state == 'active'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="GitLab Cloud"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="base_url"/>
                        </group>
                        <group>
                            <field name="api_token" password="True"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Repositories" name="repositories">
                            <field name="repository_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="gitlab_project_id"/>
                                    <field name="project_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gitlab_instance" model="ir.actions.act_window">
        <field name="name">GitLab Instances</field>
        <field name="res_model">gitlab.instance</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_gitlab_root" name="GitLab Integration" parent="project.menu_project_config" sequence="50"/>
    <menuitem id="menu_gitlab_instance" name="GitLab Instances" parent="menu_gitlab_root" action="action_gitlab_instance" sequence="10"/>
</odoo>
