<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="access_gitlab_instance" model="ir.model.access">
        <field name="name">gitlab.instance access</field>
        <field name="model_id" search="[('model', '=', 'gitlab.instance')]" model="ir.model"/>
        <field name="group_id" ref="project.group_project_manager"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="access_gitlab_repository" model="ir.model.access">
        <field name="name">gitlab.repository access</field>
